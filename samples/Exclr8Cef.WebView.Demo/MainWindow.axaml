<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cef="using:Exclr8Cef.WebView"
        x:Class="Exclr8Cef.WebView.Demo.MainWindow"
        Title="Exclr8CEF Avalonia Demo"
        Width="1200" Height="800">
    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Border Grid.Row="0" Background="#1E1E2E" Padding="16,8">
            <StackPanel Orientation="Vertical" Spacing="2">
                <TextBlock Text="Exclr8Cef.WebView — embedded Chromium inside Avalonia (OSR)"
                           Foreground="#CDD6F4" FontWeight="Bold" FontSize="14" />
                <TextBlock Name="TitleText" Foreground="#A6ADC8" FontSize="12" />
            </StackPanel>
        </Border>

        <!-- Address bar + nav buttons -->
        <Border Grid.Row="1" Background="#181825" Padding="8,6">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Left"   Name="BackButton"     Content="◀"        Click="OnBackClick"     Padding="10,4" Margin="0,0,4,0" />
                <Button DockPanel.Dock="Left"   Name="ForwardButton"  Content="▶"        Click="OnForwardClick"  Padding="10,4" Margin="0,0,4,0" />
                <Button DockPanel.Dock="Left"   Name="ReloadButton"   Content="⟳"        Click="OnReloadClick"   Padding="10,4" Margin="0,0,4,0" />
                <Button DockPanel.Dock="Left"   Name="StopButton"     Content="✕"        Click="OnStopClick"     Padding="10,4" Margin="0,0,8,0" />
                <Button DockPanel.Dock="Right"  Name="SavePdfButton"  Content="Save PDF"   Click="OnSavePdfClick"  Padding="10,4" Margin="6,0,0,0" />
                <Button DockPanel.Dock="Right"  Name="RunJsButton"    Content="Run JS"     Click="OnRunJsClick"    Padding="10,4" Margin="6,0,0,0" />
                <Button DockPanel.Dock="Right"  Name="DevToolsButton" Content="DevTools"   Click="OnDevToolsClick" Padding="10,4" />
                <TextBox Name="AddressBox" Watermark="URL" KeyDown="OnAddressKeyDown" VerticalAlignment="Center" />
            </DockPanel>
        </Border>

        <cef:WebView Grid.Row="2" Name="Browser" />

        <Border Grid.Row="3" Background="#181825" Padding="12,4">
            <TextBlock Name="StatusText" Foreground="#A6E3A1" FontSize="11" />
        </Border>
    </Grid>
</Window>
